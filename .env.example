# ===========================================
# Dictator — Environment Variables
# ===========================================
# Copy this file to .env and fill in your values
# DO NOT commit the .env file to version control

# --- MongoDB Atlas (Free M0 Cluster) ---
# Get your connection string from https://cloud.mongodb.com
MONGODB_URI=
MONGODB_DB_NAME=dictator

# --- Redis (Local Docker) ---
REDIS_URL=redis://localhost:6379/0

# --- JWT Authentication ---
JWT_SECRET=change-this-to-a-random-secret-string-at-least-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24

# --- File Uploads ---
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10

# --- ML Models (Hugging Face Model IDs) ---
HF_MODEL_IMAGE=umm-maybe/AI-image-detector
HF_MODEL_TEXT=openai-community/roberta-base-openai-detector

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

# --- Razorpay (Add later for subscriptions) ---
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=

# --- AWS (Phase 3 — Deployment) ---
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=ap-south-1
# S3_BUCKET_NAME=
